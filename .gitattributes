# Force LF line endings for all text files (prevents CRLF drift from
# Windows mounts, sandbox tools, and editor mismatches).
* text=auto eol=lf

# Explicit overrides for file types we care about
*.py text eol=lf
*.md text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.txt text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
*.sh text eol=lf

# Binary files - never touch line endings
*.wav binary
*.mp3 binary
*.flac binary
*.ogg binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.mp4 binary
*.avi binary
*.mov binary
*.zip binary
*.tar.gz binary
*.whl binary
